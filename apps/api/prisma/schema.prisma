/**
 * Prisma Schema for SupportHub CRM
 * Defines the core data models for the authentication and multi-tenant system.
 * - User: Stores user credentials, profile, and email verification state
 * - Workspace: Represents a tenant workspace (one per company registration)
 * - Role: Enum for role-based access control (ADMIN / AGENT)
 */

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Registered user of the platform.
/// Each user belongs to exactly one Workspace (tenant workspace).
model User {
  id                 String          @id @default(uuid()) /// Primary key — UUID for multi-tenant safety
  email              String          @unique /// Login identifier — must be globally unique
  firstName          String /// User's first name
  lastName           String /// User's last name
  phone              String /// Contact phone number
  passwordHash       String /// bcrypt-hashed password — never store plain text
  isEmailVerified    Boolean         @default(false) /// Flipped to true after clicking the verification link
  emailVerifyToken   String?         @unique /// One-time token sent in the verification email
  emailVerifyExpires DateTime? /// Token expiry — 24 hours from registration
  refreshToken       String? /// Current refresh token for token rotation
  role               Role            @default(ADMIN) /// ADMIN for the registering user; AGENT for invitees
  workspaceId        String /// FK to the tenant workspace
  workspace          Workspace       @relation(fields: [workspaceId], references: [id])
  invitationsSent    Invitation[] /// Invitations sent by this user
  assignedTickets    Ticket[] /// Tickets assigned to this user
  comments           TicketComment[] /// Comments authored by this user
  assignmentRules    AssignmentRule[] @relation("RuleAssignee") /// Rules targeting this user
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

/// Tenant workspace created during registration.
/// The slug is derived from the company name and used for tenant routing.
model Workspace {
  id            String          @id @default(uuid()) /// Primary key — UUID
  subdomain     String          @unique /// URL-safe subdomain identifier, e.g. "acmecorp"
  company       String /// Original company name provided at registration
  users         User[] /// All users belonging to this workspace
  invitations     Invitation[] /// Invitations for this workspace
  customers       Customer[] /// External customers in this workspace
  tickets         Ticket[] /// All tickets in this workspace
  tags            Tag[] /// Tags for categorization
  tagSuggestions  TagSuggestion[] /// AI-suggested tags pending review
  emailAccounts   EmailAccount[] /// Connected email accounts (Gmail / Outlook)
  emailMessages   EmailMessage[] /// Processed inbound email records
  theme           WorkspaceTheme? /// White-label branding configuration
  assignmentRules AssignmentRule[] /// Admin-configured assignment rules
  aiDecisionLogs  AIDecisionLog[] /// AI classification audit trail
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

/// Role-based access control enum.
/// ADMIN — Full access (assigned to the user who registers the workspace)
/// AGENT — Limited access (assigned to users invited later)
enum Role {
  ADMIN
  AGENT
}

/// Invitation for a new agent to join a workspace.
model Invitation {
  id          String           @id @default(uuid())
  email       String
  token       String           @unique
  expiresAt   DateTime
  status      InvitationStatus @default(PENDING)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  invitedBy   String
  inviter     User             @relation(fields: [invitedBy], references: [id])
  createdAt   DateTime         @default(now())

  @@unique([email, workspaceId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

/// External end-user who submits tickets.
/// Separate from User (internal team members).
model Customer {
  id          String    @id @default(uuid())
  email       String
  name        String
  phone       String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  tickets     Ticket[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([email, workspaceId])
}

/// Support ticket created by or on behalf of a customer.
model Ticket {
  id            String          @id @default(uuid())
  ticketNumber  Int
  subject       String
  description   String
  status        TicketStatus    @default(OPEN)
  priority      TicketPriority  @default(MEDIUM)
  source        TicketSource    @default(MANUAL) /// How the ticket was created
  customerId    String
  customer      Customer        @relation(fields: [customerId], references: [id])
  assigneeId    String?
  assignee      User?           @relation(fields: [assigneeId], references: [id])
  workspaceId   String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  comments        TicketComment[]
  tags            Tag[]
  tagSuggestions  TagSuggestion[] /// AI-suggested tags pending agent review
  emailMessages   EmailMessage[] /// Associated inbound email records
  aiDecisionLogs  AIDecisionLog[] /// AI classification audit trail
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([ticketNumber, workspaceId])
}

/// A comment on a ticket — either a public reply or an internal note.
model TicketComment {
  id         String   @id @default(uuid())
  body       String
  isInternal Boolean  @default(false) /// true = internal note, false = public reply
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
}

/// Tag category enum — each tag belongs to exactly one category.
enum TagCategory {
  ISSUE_TYPE /// Bug, Feature request, Question, Complaint, etc.
  DEPARTMENT /// Billing, Technical support, Sales, Legal, etc.
  PRODUCT_AREA /// Mobile app, Web app, API, Integrations, etc.
  SENTIMENT /// Angry, Frustrated, Neutral, Satisfied, Urgent tone
  SLA /// SLA breach risk, VIP customer, First response due
}

/// Tag for categorizing tickets within a workspace.
/// Tags are grouped into categories with a controlled vocabulary.
model Tag {
  id          String        @id @default(uuid())
  name        String
  category    TagCategory /// Which category this tag belongs to
  isSystem    Boolean       @default(false) /// true = predefined, cannot be deleted
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])
  tickets     Ticket[]
  suggestions TagSuggestion[] /// AI suggestions referencing this tag

  @@unique([name, category, workspaceId])
}

/// AI-suggested tag for a ticket — pending agent review.
/// Created when the AI's confidence is below the 70% threshold.
model TagSuggestion {
  id          String           @id @default(uuid())
  tagId       String
  tag         Tag              @relation(fields: [tagId], references: [id])
  ticketId    String
  ticket      Ticket           @relation(fields: [ticketId], references: [id])
  confidence  Float /// 0.0–1.0 confidence score from Gemini
  status      SuggestionStatus @default(PENDING)
  reviewedBy  String? /// userId who accepted/rejected
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([workspaceId, tagId, ticketId])
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/// Admin-configured rule for auto-assigning tickets based on tags.
/// Rules are evaluated in priority order — first match wins.
model AssignmentRule {
  id         String             @id @default(uuid())
  name       String /// Human-readable label, e.g. "Billing tickets"
  priority   Int /// Execution order — lower = evaluated first
  isEnabled  Boolean            @default(true)

  /// JSON: { operator: "AND"|"OR", conditions: [{ category, tagName }] }
  conditions Json

  /// Assignment target
  assigneeId String? /// Specific agent (nullable if round-robin)
  assignee   User?              @relation("RuleAssignee", fields: [assigneeId], references: [id])
  strategy   AssignmentStrategy @default(SPECIFIC)

  /// Optional actions alongside assignment
  setPriority TicketPriority? /// Override ticket priority
  flagUrgent  Boolean          @default(false)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum AssignmentStrategy {
  SPECIFIC /// Assign to a named agent
  ROUND_ROBIN /// Distribute evenly across workspace agents
}

/// Audit log for every AI classification decision.
/// Stores what the AI returned, which tags were applied/suggested,
/// and which assignment rule fired.
model AIDecisionLog {
  id            String          @id @default(uuid())
  ticketId      String
  ticket        Ticket          @relation(fields: [ticketId], references: [id])

  /// AI output
  rawResponse   Json /// Full Gemini response for debugging
  tagsApplied   Json /// [{ name, category, confidence }]
  tagsSuggested Json /// [{ name, category, confidence }] (below threshold)
  prioritySet   TicketPriority? /// Priority determined by the AI

  /// Assignment result
  ruleId     String? /// Which rule matched
  ruleName   String? /// Snapshot of rule name at time of decision
  assigneeId String? /// Who the ticket was assigned to

  /// Performance
  processingMs Int /// How long the Gemini call took
  modelVersion String /// e.g. "gemini-2.0-flash"

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
}

enum TicketStatus {
  OPEN
  PENDING
  SOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// How the ticket was created.
enum TicketSource {
  MANUAL /// Created manually by an agent
  EMAIL /// Auto-created from an inbound email
}

/// Email provider enum.
enum EmailProvider {
  GMAIL
  OUTLOOK
}

/// Connected email account for a workspace.
/// Stores encrypted OAuth tokens for Gmail or Outlook API access.
model EmailAccount {
  id              String        @id @default(uuid())
  provider        EmailProvider /// GMAIL or OUTLOOK
  email           String /// The connected email address
  accessTokenEnc  String /// AES-256-GCM encrypted access token
  refreshTokenEnc String /// AES-256-GCM encrypted refresh token
  tokenExpiresAt  DateTime? /// When the current access token expires
  watchExpiry     DateTime? /// Gmail watch / Outlook subscription expiry
  watchResourceId String? /// Gmail watch resourceId or Outlook subscriptionId
  historyId       String? /// Gmail historyId for incremental sync
  isActive        Boolean       @default(true) /// Whether this account is currently active
  workspaceId     String
  workspace       Workspace     @relation(fields: [workspaceId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([provider, workspaceId]) /// One account per provider per workspace
}

/// Tracks processed email Message-IDs for deduplication and threading.
/// Each inbound email that creates or appends to a ticket gets a record here.
model EmailMessage {
  id          String    @id @default(uuid())
  messageId   String /// RFC 2822 Message-ID header (globally unique per email)
  references  String? /// Serialized References/In-Reply-To headers for threading
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([messageId, workspaceId]) /// Prevents duplicate processing
}

/// White-label theming configuration for a workspace.
/// Stores brand colors, typography, shape, appearance, and asset URLs.
/// Created lazily on first theme update (defaults are used until then).
model WorkspaceTheme {
  id           String   @id @default(uuid())

  /// Brand colors stored as hex (converted to oklch at runtime)
  primaryColor String   @default("#4F6BF0")
  accentColor  String   @default("#7C3AED")

  /// Typography — Google Font family name
  fontFamily   String   @default("Inter")

  /// Shape — border-radius in rem
  borderRadius Float    @default(0.375)

  /// Appearance — default color mode ("light" | "dark" | "system")
  defaultMode  String   @default("system")

  /// Assets — CloudFront URLs (nullable until uploaded)
  logoUrl      String?
  faviconUrl   String?

  /// Relation — one-to-one with Workspace
  workspaceId  String    @unique
  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
