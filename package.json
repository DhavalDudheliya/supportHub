{
  "name": "my-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "dev": "turbo dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "prisma:generate": "pnpm --filter api exec prisma generate",
    "prisma:studio": "pnpm --filter api exec prisma studio",
    "prisma:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:push": "pnpm --filter api exec prisma db push"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@supporthub/eslint-config": "workspace:*",
    "@supporthub/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}
